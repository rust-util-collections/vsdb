{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit(docs/audit.md)",
      "Write(docs/audit.md)",
      "Edit(Cargo.toml)",
      "Edit(core/Cargo.toml)",
      "Edit(strata/Cargo.toml)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo metadata:*)",
      "Bash(make fmt)",
      "Bash(make lint)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)"
    ],
    "deny": [
      "Bash(make clean_all)",
      "Bash(git stash)",
      "Bash(git stash:*)",
      "Bash(git clean)",
      "Bash(git clean:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)",
      "Bash(git add -A)",
      "Bash(git add -A:*)",
      "Bash(git add --all)",
      "Bash(git add --all:*)",
      "Bash(git add -u)",
      "Bash(git add -u:*)",
      "Bash(git add --update)",
      "Bash(git add --update:*)",
      "Bash(git add .)",
      "Bash(git commit --amend)",
      "Bash(git commit --amend:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --soft)",
      "Bash(git reset --soft:*)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push * --force)",
      "Bash(git push * --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push * --force-with-lease:*)",
      "Bash(git filter-branch:*)",
      "Bash(git replace:*)"
    ]
  }
}
